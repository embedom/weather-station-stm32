{
  "problemMatcher": [
    {
      "owner": "clang-tidy-error",
      "severity": "error",
      "pattern": [
        {
          "regexp": "^(.+?):(\\d+):(\\d+):\\s+error:\\s+(.+)\\s+\\[(.+)\\]$",
          "file": 1,
          "line": 2,
          "column": 3,
          "message": 4
        }
      ]
    },
    {
      "owner": "clang-tidy-warning",
      "severity": "warning",
      "pattern": [
        {
          "regexp": "^(.+?):(\\d+):(\\d+):\\s+warning:\\s+(.+)\\s+\\[(.+)\\]$",
          "file": 1,
          "line": 2,
          "column": 3,
          "message": 4
        }
      ]
    }
  ]
}
