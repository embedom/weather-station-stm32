{
    "version": 3,
    "configurePresets": [
        {
            "name": "default",
            "hidden": true,
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/",
            "toolchainFile": "${sourceDir}/CMake/dep-arm-none-eabi-gcc.cmake",
            "cacheVariables": {
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
            }
        },
        {
            "name": "Debug",
            "inherits": "default",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug"
            }
        },
        {
            "name": "Release",
            "inherits": "default",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release"
            }
        },
        {
            "name": "CI-Debug",
            "inherits": "Debug",
            "cacheVariables": {
                "BOOTSTRAP_CLANG_TOOLS": "OFF",
                "ENABLE_CLANG_FORMAT": "OFF",
                "ENABLE_CLANG_TIDY": "ON"
            }
        },
        {
            "name": "CI-Release",
            "inherits": "Release",
            "cacheVariables": {
                "BOOTSTRAP_CLANG_TOOLS": "OFF",
                "ENABLE_CLANG_FORMAT": "OFF",
                "ENABLE_CLANG_TIDY": "OFF"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "Debug",
            "configurePreset": "Debug"
        },
        {
            "name": "Release",
            "configurePreset": "Release"
        },
        {
            "name": "CI-Debug",
            "configurePreset": "CI-Debug"
        },
        {
            "name": "CI-Release",
            "configurePreset": "CI-Release"
        }
    ]
}