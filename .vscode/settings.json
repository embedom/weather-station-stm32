{
    "cmake.generator": "Ninja",
    "cmake.configureArgs": [
        "-DCMAKE_TOOLCHAIN_FILE=${workspaceFolder}/CMake/dep-arm-none-eabi-gcc.cmake"
    ],
    "editor.formatOnSave": true,
    "[c]": {
        "editor.defaultFormatter": "ms-vscode.cpptools"
    },
    "[cpp]": {
        "editor.defaultFormatter": "ms-vscode.cpptools"
    },
    "C_Cpp.clang_format_path": "${workspaceFolder}/Tools/clang/bin/clang-format",
    "C_Cpp.clang_format_style": "file"
}